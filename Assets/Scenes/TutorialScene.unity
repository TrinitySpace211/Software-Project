    - target: {fileID: 582196051590256123, guid: 79f7817e938e3de45b8dfd67d1d9060c, type: 3}
      propertyPath: tutorialMessages.Array.size
      value: 6
      objectReference: {fileID: 0}
    - target: {fileID: 582196051590256123, guid: 79f7817e938e3de45b8dfd67d1d9060c, type: 3}
      propertyPath: 'tutorialMessages.Array.data[0]'
      value: "You made it out of the tunnel. The city ahead is silent\u2026 but not
        empty.  "
      objectReference: {fileID: 0}
    - target: {fileID: 582196051590256123, guid: 79f7817e938e3de45b8dfd67d1d9060c, type: 3}
      propertyPath: 'tutorialMessages.Array.data[1]'
      value: "A final transmission warned you: in ten days, a rescue helicopter will
        arrive. But only if the city\u2019s fuel tank is still intact. It\u2019s
        the last refueling point in range. If it\u2019s destroyed, the helicopter
        can\u2019t reach you or make it back.  "
      objectReference: {fileID: 0}
    - target: {fileID: 582196051590256123, guid: 79f7817e938e3de45b8dfd67d1d9060c, type: 3}
      propertyPath: 'tutorialMessages.Array.data[2]'
      value: "You\u2019re not alone. Someone else survived here. He knows how to
        turn scrap into weapons, upgrades and defenses. He will help you stay alive. "
      objectReference: {fileID: 0}
    - target: {fileID: 582196051590256123, guid: 79f7817e938e3de45b8dfd67d1d9060c, type: 3}
      propertyPath: 'tutorialMessages.Array.data[3]'
      value: During the day, search the city. Abandoned containers may still hold
        scrap. Collect it and prepare.
      objectReference: {fileID: 0}
    - target: {fileID: 582196051590256123, guid: 79f7817e938e3de45b8dfd67d1d9060c, type: 3}
      propertyPath: 'tutorialMessages.Array.data[4]'
      value: 'At night, the infected come. They will attack the fuel tank. If it
        falls, your escape is gone.  '
      objectReference: {fileID: 0}
    - target: {fileID: 582196051590256123, guid: 79f7817e938e3de45b8dfd67d1d9060c, type: 3}
      propertyPath: 'tutorialMessages.Array.data[5]'
      value: 'You have ten days. Protect the fuel tank. Be ready.  '
      objectReference: {fileID: 0}
    - target: {fileID: 582196051590256123, guid: 79f7817e938e3de45b8dfd67d1d9060c, type: 3}
      propertyPath: 'tutorialMessages.Array.data[6]'
      value: 'You have ten days. Protect the fuel tank. Be ready.  '
      objectReference: {fileID: 0}
